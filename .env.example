# ====================================
# Local Development (Docker PostgreSQL)
# ====================================
POSTGRES_DB=dateclick
POSTGRES_USER=dateclick
POSTGRES_PASSWORD=dateclick

# Spring Profile
SPRING_PROFILES_ACTIVE=local

# ====================================
# Production (Supabase PostgreSQL)
# ====================================
# Uncomment and configure for production deployment
# DB_HOST=aws-1-ap-northeast-2.pooler.supabase.com
# DB_PORT=6543
# DB_NAME=dateclick
# DB_USERNAME=postgres.xxxxxxxxxxxxx
# DB_PASSWORD=your_supabase_password
# SPRING_PROFILES_ACTIVE=prod

# Port Configuration (for worktree environments)
# Leave default (8080/3000) for main worktree
# Use different ports for other worktrees to avoid conflicts
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Kakao Maps API Configuration
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
KAKAO_JAVASCRIPT_KEY=your_kakao_javascript_key_here

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Chroma DB (로컬 기본: 미사용. 필요 시 docker compose --profile db up -d chroma 후 CHROMA_ENABLED=true)
CHROMA_ENABLED=false
# CHROMA_PORT=8000
# CHROMA_DB_URL=http://chroma:8000

# ====================================
# Sentry Error Monitoring
# ====================================
# Backend Sentry DSN (https://sfn-oh.sentry.io/settings/projects/lian-date-app-backend/keys/)
SENTRY_DSN_BACKEND=
# Frontend Sentry DSN (https://sfn-oh.sentry.io/settings/projects/lian-date-app-frontend/keys/)
NEXT_PUBLIC_SENTRY_DSN=
# Performance traces sampling rate (0.0~1.0, 로컬: 0.0 권장)
SENTRY_TRACES_SAMPLE_RATE=0.0
# Source maps 업로드용 Auth Token
# https://sfn-oh.sentry.io/settings/auth-tokens/ 에서 발급
SENTRY_AUTH_TOKEN=

# ====================================
# Slack Error Alerting
# ====================================
SLACK_WEBHOOK_URL_ERROR=

# ====================================
# Langfuse (LLM Observability)
# ====================================
# https://us.cloud.langfuse.com 에서 발급 (US 리전 사용)
LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
